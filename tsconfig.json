{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",                        
      "lib": ["DOM", "ESNext"],
      "moduleResolution": "node",
      "strict": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "dist",
      "baseUrl": ".",
      "paths": {
        "@utils/*": ["utils/*"]
      }
    },
    "include": ["tests", "pages", "playwright.config.ts", "utils"]
  }